# =========================
# App
# =========================
APP_ENV=development
APP_NAME=stock-agent

# =========================
# LLM Providers
# =========================
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

OPENAI_MODEL_PLANNER=gpt-5.4
OPENAI_MODEL_FINALIZER=gpt-5.4
OPENAI_MODEL_COMMITTEE_DRAFTER=gpt-5.4
OPENAI_MODEL_COMMITTEE_FINALIZER=gpt-5.4
GEMINI_MODEL_REVIEWER=gemini-2.5-pro
GEMINI_MODEL_COMMITTEE_REVIEWER=gemini-2.5-pro
GEMINI_MODEL_FALLBACKS=gemini-2.5-pro,gemini-2.5-flash

LLM_TIMEOUT_SECONDS=60
LLM_RETRY_TIMES=2
USE_LIVE_LLM=false

# =========================
# ValueCell + Dedicated Real Browser
# =========================
VALUECELL_CHAT_URL=https://valuecell.cn/zh/chat
CHROME_CDP_URL=http://127.0.0.1:9222
CHROME_USER_DATA_DIR=./sessions/chrome-valuecell-profile

VALUECELL_TASK_TIMEOUT_SECONDS=900
VALUECELL_POLL_INTERVAL_SECONDS=5
BROWSER_EXECUTION_MODE=attach_existing
BROWSER_FAILURE_POLICY=manual_intervention
# Testing helper: set to pass to bypass ValueCell browser and return deterministic success payload.
# Allowed: off, pass
VALUECELL_MOCK_MODE=off

# =========================
# Storage / Paths
# =========================
DATABASE_URL=sqlite:///./data/app.db
TIMEZONE=America/New_York

SCREENSHOTS_DIR=./screenshots
ARTIFACTS_DIR=./artifacts
LOG_DIR=./logs
LOG_LEVEL=INFO

# =========================
# Scheduler (Cron v1)
# =========================
SCHEDULER_ENABLED=true
SCHEDULER_DEFAULT_CRON="0 12 * * *"
SCHEDULER_MISFIRE_GRACE_SECONDS=120
SCHEDULER_MAX_INSTANCES=1
SCHEDULER_COALESCE=true

# =========================
# Service Ports
# =========================
API_HOST=0.0.0.0
API_PORT=8000
STREAMLIT_PORT=8501
API_TIMEOUT_SECONDS=90
API_RUN_TIMEOUT_SECONDS=1800

# =========================
# Discord Bridge
# =========================
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=0
DISCORD_GUILD_ID=0

DISCORD_ALLOWED_CHANNEL_IDS=
DISCORD_RUN_CHANNEL_IDS=
DISCORD_SCHEDULE_CHANNEL_IDS=
DISCORD_RESULT_CHANNEL_ID=0

DISCORD_API_BASE_URL=http://127.0.0.1:8000
DISCORD_RESPONSE_FORMAT=embed
DISCORD_LONGRUN_ACK=true

DISCORD_SCHEDULE_MANAGER_ROLE_IDS=
DISCORD_RUN_ROLE_IDS=
DISCORD_ADMIN_USER_IDS=
DISCORD_SCHEDULE_ALLOW_EVERYONE=true
DISCORD_CANCEL_BY_NAME_ALLOWED=true

DISCORD_TASK_WATCH_INTERVAL_SECONDS=5
DISCORD_TASK_WATCH_LOOKBACK_MINUTES=180
DISCORD_DELIVERY_STATE_PATH=./data/discord_bridge_state.json
DISCORD_HTTP_TIMEOUT_SECONDS=30
